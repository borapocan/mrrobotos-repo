# Maintainer: Bora Poçan <borapocan@github.com>
pkgname=mrmanager
pkgver=1.0
pkgrel=1
pkgdesc="MrManager - MrRobotOS custom GTK4 Task Manager"
arch=('x86_64')
license=('MIT')
depends=('gtk4')
makedepends=('gcc' 'make' 'pkg-config')
url="https://github.com/borapocan/mrmanager"
source=("git+https://github.com/borapocan/mrmanager.git")
sha256sums=('SKIP')

build() {
    cd "$srcdir/mrmanager"
    make
}

package() {
    cd "$srcdir/mrmanager"
    install -Dm755 mrmanager "$pkgdir/usr/bin/mrmanager"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
