# Maintainer: Bora Poçan <borapocan@github.com>
pkgname=mrdotfiles
pkgver=1.0
pkgrel=1
pkgdesc="MrDotfiles - MrRobotOS dotfiles, configs and scripts"
arch=('any')
license=('MIT')
depends=('zsh' 'rofi' 'dunst' 'yazi')
url="https://github.com/borapocan/mrdotfiles"
source=("git+https://github.com/borapocan/mrdotfiles.git")
sha256sums=('SKIP')

package() {
    cd "$srcdir/mrdotfiles"

    # zsh config
    install -Dm644 .config/zsh/.zshrc \
        "$pkgdir/etc/skel/.config/zsh/.zshrc"

	# wallpaper
    install -Dm644 Pictures/wp2.jpg "$pkgdir/etc/skel/Pictures/wp2.jpg"

    # fehbg
    install -Dm755 .fehbg "$pkgdir/etc/skel/.fehbg"

    # shell profile files
    install -Dm644 .zprofile  "$pkgdir/etc/skel/.zprofile"
    install -Dm644 .xinitrc   "$pkgdir/etc/skel/.xinitrc"
    install -Dm644 .xprofile  "$pkgdir/etc/skel/.xprofile"

    # rofi config
    cp -r .config/rofi "$pkgdir/etc/skel/.config/"

    # dunst config
    cp -r .config/dunst "$pkgdir/etc/skel/.config/"

    # yazi config
    cp -r .config/yazi "$pkgdir/etc/skel/.config/"

    # panel scripts
    install -d "$pkgdir/usr/local/bin/mrpanel-genmon-scripts"
    install -Dm755 .local/bin/mrpanel-genmon-scripts/* \
        "$pkgdir/usr/local/bin/mrpanel-genmon-scripts/"

    # system scripts
    install -d "$pkgdir/usr/local/bin/system-scripts"
    install -Dm755 .local/bin/system-scripts/* \
        "$pkgdir/usr/local/bin/system-scripts/"
}
