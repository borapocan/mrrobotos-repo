# Maintainer: Bora Poçan <borapocan@github.com>
pkgname=mrdwm
pkgver=6.4
pkgrel=1
pkgdesc="MrDWM - MrRobotOS Dynamic Window Manager with custom patches"
arch=('x86_64')
license=('MIT')
depends=('libx11' 'libxft' 'libxinerama' 'freetype2' 'imlib2' 'libxcb')
makedepends=('gcc' 'make')
conflicts=('dwm')
provides=('dwm')
url="https://github.com/borapocan/mrdwm"
source=("git+https://github.com/borapocan/mrdwm.git")
sha256sums=('SKIP')

build() {
    cd "$srcdir/mrdwm"
    make
}

package() {
    cd "$srcdir/mrdwm"
    make PREFIX="$pkgdir/usr" install
}
